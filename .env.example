# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE

# ── Instructions ───────────────────────────────────────────────
# 1. Copy this file and rename it to: .env.local
# 2. Replace the values above with your actual Supabase credentials
# 3. NEVER commit .env.local to git (it's in .gitignore)
# 4. Add these same variables in Vercel → Project Settings → Environment Variables
